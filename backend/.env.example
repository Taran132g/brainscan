# Backend environment variables (FastAPI)
# Copy to backend/.env and fill in real values. Never commit .env.

ANTHROPIC_API_KEY=sk-ant-...
PINECONE_API_KEY=pcsk-...
PINECONE_INDEX_NAME=finding-founders

# Supabase URL — used to fetch public keys from JWKS endpoint
# for verifying ES256/RS256-signed tokens (the new Supabase default).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Legacy HS256 shared secret — only needed if your Supabase project still
# issues HS256-signed tokens. New projects can leave this blank.
# Find at: Supabase → Settings → JWT Keys → Legacy JWT Secret
SUPABASE_JWT_SECRET=your-legacy-secret-or-leave-blank

# Service role key — used by the backend to write to Postgres tables
# bypassing RLS. NEVER expose this to the browser.
# Find at: Supabase → Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----- Stripe -----
# Secret key (server-only). dashboard.stripe.com → Developers → API keys
# Use sk_test_... while developing, sk_live_... in production
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret. Get this from `stripe listen --print-secret`
# (Stripe CLI) for local dev, or from the webhook settings page in production
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs (one per pricing tier — create products in the Stripe dashboard)
STRIPE_PRICE_BRAIN_CARD=price_...       # $0.99 one-time — brain card only
STRIPE_PRICE_FULL_MEMBERSHIP=price_...  # $3.99/month — full membership recurring
STRIPE_PRICE_EXTRA_UPLOAD=price_...     # $0.99 one-time — additional re-upload
STRIPE_PRICE_UPGRADE=price_...          # $3.00 one-time — upgrade brain_card → full

# Public frontend URL used in checkout success/cancel redirects
FRONTEND_URL=http://localhost:3000

# Backend public URL (used by GitHub OAuth as the callback target)
BACKEND_URL=http://localhost:8001

# ----- GitHub OAuth -----
# Create an OAuth App: github.com/settings/developers → New OAuth App
#   Application name:    FindingFounders (local)
#   Homepage URL:        http://localhost:3000
#   Authorization URL:   http://localhost:8001/api/github/callback
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
