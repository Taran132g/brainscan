# Backend environment variables (FastAPI)
# Copy to backend/.env and fill in real values. Never commit .env.

ANTHROPIC_API_KEY=sk-ant-...
PINECONE_API_KEY=pcsk-...
PINECONE_INDEX_NAME=finding-founders

# Supabase JWT verification — get from Supabase dashboard:
# Settings → API → JWT Settings → "JWT Secret" (HS256 symmetric secret)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here
