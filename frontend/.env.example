# Frontend environment (Next.js)
# Copy to frontend/.env.local and fill in real values. Never commit .env.local.

# Where the FastAPI backend lives.
#   local dev:   http://localhost:8001
#   production:  https://your-backend-host
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001

# Public URL of this frontend (used for share links / OG tags).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — project URL + anon (public) key.
# Find at: Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=...
NEXT_PUBLIC_SUPABASE_ANON_KEY=...
