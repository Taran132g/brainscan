# ---------- Secrets — never commit ----------
# Match any .env file anywhere in the tree
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Common secret/credential file patterns
*.pem
*.key
*.p12
*.pfx
*.crt
secrets/
credentials/
*credentials*.json
*secret*.json
*token*.json
*.tfvars

# Cloud CLI credentials
.aws/
.gcloud/
.azure/

# ---------- Python ----------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
backend/venv/
backend/.venv/
venv/
.venv/

# ---------- Node / Next.js ----------
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.vercel/

# ---------- OS ----------
.DS_Store
Thumbs.db

# ---------- IDE ----------
.vscode/
.idea/
*.swp
*.swo

# ---------- Logs + runtime ----------
*.log
*.pid
npm-debug.log*

# ---------- ML / Pinecone cache ----------
*.pkl
*.bin
